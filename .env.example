# Email signup endpoint.
# The form posts { "email", "source" } as JSON here.
#
# Leave this UNSET in normal use: the form defaults to the first-party
# /api/subscribe Pages Function (backed by Cloudflare D1, see wrangler.toml).
# Only set this to override with a different backend (e.g. an ESP proxy URL).
PUBLIC_SUBSCRIBE_ENDPOINT=
