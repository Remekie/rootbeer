---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { privacyPage } from '../lib/site';
---
<Base
  title="Privacy Policy | Zyra Root Beer Rush"
  description="What information rootbeervodka.com collects, why, and how to opt out."
>
  <Header />
  <main id="main">
    <section class="section section--dark privacy">
      <div class="container privacy__inner">
        <p class="kicker">Legal</p>
        <hr class="rule" />
        <h1>{privacyPage.title}</h1>
        <p class="privacy__updated">Last updated: {privacyPage.updated}</p>
        <p class="lead privacy__intro" set:html={privacyPage.intro} />
        {privacyPage.sections.map((section) => (
          <div class="privacy__section">
            <h2>{section.heading}</h2>
            {section.paragraphs.map((p) => (
              <p set:html={p} />
            ))}
          </div>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  .privacy__inner { max-width: 42rem; }
  .privacy__updated {
    margin-top: var(--space-4);
    font-size: var(--fs-kicker);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-on-dark-mute);
  }
  .privacy__intro { margin-top: var(--space-6); color: var(--ink-on-dark-mute); }
  .privacy__section { margin-top: var(--space-12); }
  .privacy__section h2 { font-size: var(--fs-h3); }
  .privacy__section p { margin-top: var(--space-4); color: var(--ink-on-dark-mute); line-height: 1.7; }
  .privacy__inner :global(a) {
    color: var(--ink-on-dark);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }
</style>
