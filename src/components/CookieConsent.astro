---
import { cookieConsent } from '../lib/site';
// Implied-consent notice: analytics is already running (Base.astro grants by
// default), so this banner informs and offers an opt-out rather than gating.
// 'zyra-cookie-ok' in localStorage: '1' = acknowledged, '0' = declined;
// absent = not yet answered, so the banner shows. Visitors who accepted under
// the old opt-in model already hold '1' and never see the banner again.
// Mirrors drinkzyra.com's CookieConsent (same brand family, same key).
---
<div class="cookie" data-cookie hidden>
  <div class="container cookie__inner">
    <p class="cookie__text">
      {cookieConsent.body}
      <a class="cookie__link" href="/privacy">{cookieConsent.linkLabel}</a>
    </p>
    <div class="cookie__actions">
      <button class="cookie__decline" type="button" data-cookie-decline>{cookieConsent.decline}</button>
      <button class="cookie__btn" type="button" data-cookie-accept>{cookieConsent.accept}</button>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var KEY = 'zyra-cookie-ok';
    var el = document.querySelector('[data-cookie]');
    if (!el) return;
    var stored = null;
    try { stored = localStorage.getItem(KEY); } catch (e) {}
    if (stored === '1' || stored === '0') return;
    el.hidden = false;
    el.querySelector('[data-cookie-accept]').addEventListener('click', function () {
      try { localStorage.setItem(KEY, '1'); } catch (e) {}
      el.hidden = true;
    });
    el.querySelector('[data-cookie-decline]').addEventListener('click', function () {
      try { localStorage.setItem(KEY, '0'); } catch (e) {}
      try {
        if (window.gtag) {
          window.gtag('consent', 'update', { analytics_storage: 'denied' });
        }
      } catch (e) {}
      el.hidden = true;
    });
  })();
</script>

<style>
  .cookie {
    position: fixed;
    inset-block-end: 0;
    inset-inline: 0;
    z-index: 150;
    background: color-mix(in srgb, var(--espresso) 96%, transparent);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    border-top: 1px solid var(--line-on-dark);
    padding-block: var(--space-4);
  }
  .cookie[hidden] { display: none; }
  .cookie__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
  }
  .cookie__text { color: var(--ink-on-dark-mute); font-size: 0.92rem; margin: 0; }
  .cookie__link {
    color: var(--ink-on-dark);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }
  .cookie__actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex: 0 0 auto;
  }
  .cookie__decline {
    background: none;
    border: 0;
    padding: 0;
    font-family: var(--font-body);
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--ink-on-dark-mute);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }
  .cookie__decline:hover { color: var(--ink-on-dark); }
  .cookie__btn {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 2.75rem;
    padding-inline: var(--space-6);
    border: 0;
    border-radius: var(--radius);
    background: var(--gold);
    color: var(--base);
    font-family: var(--font-body);
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }
  .cookie__btn:hover { background: var(--gold-deep); }

  @media (max-width: 40rem) {
    .cookie__inner { flex-direction: column; align-items: stretch; text-align: center; gap: var(--space-3); }
    .cookie__actions { justify-content: center; }
  }
</style>
