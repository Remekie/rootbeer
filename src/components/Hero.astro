---
import { Image } from 'astro:assets';
import bottle from '../assets/bottle-rootbeerrush.png';
import SignupForm from './SignupForm.astro';
import { product } from '../lib/site';

// Real product facts only — a label-style spec strip, never invented badges.
const specs = ['Alberta-distilled', product.botanical, product.abv, product.volume];
---
<section class="hero">
  <div class="container hero__grid">
    <div class="hero__copy">
      <p class="kicker">Zyra Root Beer Rush</p>

      <h1 class="hero__title">
        The only all-natural <em class="hero__em">root beer vodka</em> in North America.
      </h1>

      <ul class="hero__spec" aria-label="Product facts">
        {specs.map((s) => <li>{s}</li>)}
      </ul>

      <p class="hero__sub lead">
        <strong class="hero__lede">Pour bold. Live bright.</strong> Nostalgic
        soda-fountain flavour, distilled clean. Creamy vanilla and real
        sarsaparilla, smooth and not too sweet.
      </p>

      <div class="hero__cta" id="signup">
        <p class="hero__cta-label">Get the first pour: early access and where-to-buy alerts.</p>
        <SignupForm id="signup-hero" variant="hero" />
        <a class="hero__find" href="/where-to-buy">Already looking? Find it near you →</a>
      </div>
    </div>

    <div class="hero__stage">
      <!-- One animation: a slow spotlight bloom that echoes the bottle's own studio light. -->
      <div class="hero__bloom" aria-hidden="true"></div>
      <Image
        class="hero__bottle"
        src={bottle}
        alt="A bottle of Zyra Root Beer Rush all-natural root beer vodka, lit by a warm studio spotlight"
        widths={[320, 480, 640, 785]}
        sizes="(max-width: 60rem) 60vw, 30rem"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background: var(--base);
    /* Full-viewport hero. Bottom padding is 0 so the bottle grounds on — and
       bleeds a hair past — the section floor, the way a real product hero
       stands. svh keeps it honest against mobile browser chrome. */
    min-height: 100svh;
    display: flex;
    align-items: stretch;
    /* Match the store-locator page's header→content rhythm exactly so the two
       pages feel like one site — clears the absolute nav with real breathing room. */
    padding-block: clamp(7rem, 12vw, 9rem) 0;
    overflow: hidden;
  }
  .hero__grid {
    width: 100%;
    display: grid;
    /* Bottle takes the larger share and anchors the whole composition. */
    grid-template-columns: 0.9fr 1.1fr;
    /* Top-align both columns so the bottle's cap rises to meet the headline
       ("The only") instead of the copy centering and the bottle sinking. */
    align-items: start;
    gap: clamp(2rem, 5vw, 4.5rem);
  }

  /* Edgy-but-in-brand: push the display type harder than the base h1 — bigger,
     heavier, tighter — so the claim lands like a statement, not a caption. */
  .hero__title {
    margin-top: var(--space-4);
    max-width: 17ch;
    /* Dialed back so the bottle is the hero, not the headline. */
    font-size: clamp(2.5rem, 1.4rem + 4vw, 4.5rem);
    font-weight: 760;
    line-height: 0.98;
    letter-spacing: -0.028em;
  }
  .hero__em {
    color: var(--gold);
    font-style: italic;   /* Fraunces italic — editorial emphasis on the core claim */
    font-weight: 620;
  }

  /* Label-style spec strip — real facts, hairline-separated, quiet but confident. */
  .hero__spec {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) 0;
    margin-top: var(--space-6);
    font-family: var(--font-body);
    font-size: var(--fs-kicker);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-on-dark-mute);
  }
  .hero__spec li { display: inline-flex; align-items: center; }
  .hero__spec li:not(:last-child)::after {
    content: '';
    width: 1px;
    height: 0.85em;
    margin-inline: var(--space-4);
    background: var(--line-on-dark);
  }

  .hero__sub { margin-top: var(--space-6); color: var(--ink-on-dark-mute); }
  .hero__lede {
    display: block;
    color: var(--ink-on-dark);
    font-family: var(--font-display);
    font-weight: 600;
    font-style: italic;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-2);
  }

  .hero__cta { margin-top: var(--space-8); }
  .hero__cta-label {
    font-size: 0.95rem;
    color: var(--ink-on-dark-mute);
    margin-bottom: var(--space-3);
  }
  .hero__find {
    display: inline-block;
    margin-top: var(--space-4);
    color: var(--gold);
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.01em;
    transition: color 0.15s var(--ease);
  }
  .hero__find:hover { color: #d8b25f; }

  .hero__stage {
    position: relative;
    align-self: stretch;
    display: grid;
    /* Top-align the bottle so its cap lands by the headline; it runs tall and
       bleeds off the bottom edge for weight. */
    place-items: start center;
    min-height: 0;
  }
  .hero__bottle {
    position: relative;
    z-index: 1;
    width: auto;
    /* Big enough to own the fold; bleeds off the bottom rather than the top. */
    max-height: min(92vh, 54rem);
    /* Lift the cap above the headline top line for more presence. */
    margin-top: clamp(-11rem, -10.5vh, -4rem);
    filter: drop-shadow(0 40px 70px rgba(0, 0, 0, 0.66));
  }
  .hero__bloom {
    position: absolute;
    z-index: 0;
    /* Glow follows the bottle up — spotlight behind the upper body, not the floor. */
    top: 12%;
    width: 90%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(closest-side, rgba(201, 162, 75, 0.26), rgba(201, 162, 75, 0) 70%);
    animation: bloom 7s var(--ease) infinite alternate;
  }
  @keyframes bloom {
    from { opacity: 0.5;  transform: scale(0.92); }
    to   { opacity: 1;    transform: scale(1.07); }
  }

  @media (max-width: 60rem) {
    /* Stacked: drop the full-height/grounding rules — bottle sits above copy. */
    .hero { min-height: 0; padding-block: clamp(7rem, 16vw, 9rem) clamp(3rem, 8vw, 4rem); }
    .hero__grid { grid-template-columns: 1fr; text-align: center; }
    .hero__title, .hero__sub { max-width: none; margin-inline: auto; }
    .hero__spec { justify-content: center; }
    .hero__cta { max-width: 30rem; margin-inline: auto; }
    .hero__stage { order: -1; place-items: center; }
    .hero__bottle { max-height: 52vh; margin-top: 0; }
    .hero__bloom { top: auto; }
  }
</style>
